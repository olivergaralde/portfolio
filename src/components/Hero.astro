---
import type { HeroProps } from "@types";
type Props = HeroProps;

const { name, specialty, summary, email } = Astro.props;

// Normalize to an array so this works whether `specialty` is a string or a list of titles.
const titles = Array.isArray(specialty) ? specialty : [specialty];
---

<section class="py-24 md:py-32" id="#hero">
  <h1
    class="mb-1.5 font-serif text-7xl font-bold tracking-tightest text-white sm:text-8xl md:mb-0 md:text-9xl"
  >
    {name}
  </h1>
  <p
    class="mb-9 font-serif text-4xl leading-11.5 font-bold tracking-tighter text-primary sm:text-5xl md:text-6xl"
  >
    <span
      id="typing-title"
      class="inline-block"
      data-titles={JSON.stringify(titles)}
      aria-live="polite"
    >{titles[0]}</span><span class="typing-cursor" aria-hidden="true">|</span>
  </p>
  <p class="mb-16 text-base font-normal text-neutral md:text-lg">
    {summary}
  </p>

  <a
    class="inline-block rounded-full bg-primary px-8 py-5 text-sm leading-5 font-medium text-[#fff]"
  href="/GaraldeCV.pdf"
  download="JamesOliverGaralde_Resume.pdf"
>
  Download Resume
</a>
</section>

<style>
  .typing-cursor {
    margin-left: 2px;
    animation: blink 1s step-end infinite;
  }

  @media (prefers-reduced-motion: reduce) {
    .typing-cursor {
      animation: none;
    }
  }

  @keyframes blink {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0;
    }
  }
</style>

<script>
  // Re-runs on Astro view-transitions navigation too, since it's a plain DOMContentLoaded-style init.
  function initTypingTitle() {
    const el = document.getElementById("typing-title");
    if (!el) return;
    const titleEl = el; // narrowed, non-null reference for use inside tick()

    let titles: string[] = [];
    try {
      titles = JSON.parse(titleEl.dataset.titles || "[]");
    } catch {
      titles = [];
    }
    if (titles.length <= 1) return; // Nothing to loop through.

    const prefersReducedMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;
    if (prefersReducedMotion) return; // Leave the first title static.

    const TYPE_SPEED = 70; // ms per character while typing
    const DELETE_SPEED = 40; // ms per character while deleting
    const HOLD_TIME = 1800; // ms to pause once fully typed
    const PAUSE_BEFORE_TYPE = 300; // ms to pause once fully deleted

    let titleIndex = 0;
    let charIndex = titles[0].length;
    let deleting = false;

    function tick() {
      const current = titles[titleIndex];

      if (!deleting) {
        charIndex++;
        titleEl.textContent = current.slice(0, charIndex);

        if (charIndex >= current.length) {
          deleting = true;
          setTimeout(tick, HOLD_TIME);
          return;
        }
        setTimeout(tick, TYPE_SPEED);
      } else {
        charIndex--;
        titleEl.textContent = current.slice(0, charIndex);

        if (charIndex <= 0) {
          deleting = false;
          titleIndex = (titleIndex + 1) % titles.length;
          setTimeout(tick, PAUSE_BEFORE_TYPE);
          return;
        }
        setTimeout(tick, DELETE_SPEED);
      }
    }

    setTimeout(tick, HOLD_TIME);
  }

  document.addEventListener("DOMContentLoaded", initTypingTitle);
  document.addEventListener("astro:page-load", initTypingTitle);
</script>
