---
import type { HeroProps } from "@types";
type Props = HeroProps;

const { name, specialty, summary, email } = Astro.props;

// Normalize to an array so this works whether `specialty` is a string or a list of titles.
const titles = Array.isArray(specialty) ? specialty : [specialty];
---

<section class="py-24 md:py-32" id="#hero">
  <h1
    class="mb-1.5 font-serif text-7xl font-bold tracking-tightest text-white sm:text-8xl md:mb-0 md:text-9xl"
  >
    {name}
  </h1>
  <p
    class="mb-9 font-serif text-4xl leading-11.5 font-bold tracking-tighter text-primary sm:text-5xl md:text-6xl"
  >
    <span class="title-clip relative inline-block overflow-hidden">
      <span
        id="slide-title"
        class="slide-title inline-block"
        data-titles={JSON.stringify(titles)}
        aria-live="polite"
      >{titles[0]}</span>
    </span>
  </p>
  <p class="mb-16 text-base font-normal text-neutral md:text-lg">
    {summary}
  </p>

  <a
    class="inline-block rounded-full bg-primary px-8 py-5 text-sm leading-5 font-medium text-[#fff]"
  href="/GaraldeCV.pdf"
  download="JamesOliverGaralde_Resume.pdf"
>
  Download Resume
</a>
</section>

<style>
  .slide-title {
    transition:
      opacity 0.4s ease,
      transform 0.4s ease;
  }

  .slide-title.is-out {
    opacity: 0;
    transform: translateX(1.5em);
  }

  @media (prefers-reduced-motion: reduce) {
    .slide-title {
      transition: none;
    }
  }
</style>

<script>
  // Re-runs on Astro view-transitions navigation too, since it's a plain DOMContentLoaded-style init.
  function initSlideTitle() {
    const el = document.getElementById("slide-title");
    if (!el) return;
    const titleEl = el; // narrowed, non-null reference for use inside the loop

    let titles: string[] = [];
    try {
      titles = JSON.parse(titleEl.dataset.titles || "[]");
    } catch {
      titles = [];
    }
    if (titles.length <= 1) return; // Nothing to loop through.

    const prefersReducedMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;
    if (prefersReducedMotion) return; // Leave the first title static.

    const HOLD_TIME = 3000; // ms each title stays fully visible
    const TRANSITION_TIME = 400; // ms for the slide itself (matches CSS transition)

    let titleIndex = 0;

    function showNext() {
      // Slide/fade the current title out to the left.
      titleEl.classList.add("is-out");

      setTimeout(() => {
        titleIndex = (titleIndex + 1) % titles.length;
        titleEl.textContent = titles[titleIndex];

        // Jump the next title off to the right (no transition),
        // then transition it back into place for a "sliding in" entrance.
        titleEl.style.transition = "none";
        titleEl.style.transform = "translateX(-1.5em)";
        titleEl.classList.remove("is-out");

        // Force the browser to apply the above before re-enabling the transition.
        void titleEl.offsetHeight;

        titleEl.style.transition = "";
        titleEl.style.transform = "";

        setTimeout(showNext, HOLD_TIME);
      }, TRANSITION_TIME);
    }

    setTimeout(showNext, HOLD_TIME);
  }

  document.addEventListener("DOMContentLoaded", initSlideTitle);
  document.addEventListener("astro:page-load", initSlideTitle);
</script>
